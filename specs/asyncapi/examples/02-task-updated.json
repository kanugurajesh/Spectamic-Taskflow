{
  "id": "task-updated-example",
  "name": "TASK_UPDATED_EXAMPLE",
  "before": [
    {
      "type": "http",
      "wait": "PT1S",
      "http-request": {
        "baseUrl": "http://task-service:8080",
        "path": "/tasks/2",
        "method": "PUT",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer tok_charlie_admin_8a4f"
        },
        "body": {
          "status": "in-progress",
          "assignee": "alice"
        }
      },
      "http-response": {
        "status": 200
      },
      "timeout": "PT30S"
    }
  ],
  "send": {
    "topic": "task-updated",
    "payload": {
      "taskId": "(integer)",
      "previousStatus": "pending",
      "newStatus": "in-progress",
      "updatedBy": "alice",
      "timestamp": "(datetime)"
    }
  }
}
